# --- Telegram ---
# Get this from @BotFather (/newbot)
TELEGRAM_TOKEN=123456:ABC-your-bot-token

# --- Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Google Sheets (the database) ---
# The long id from your sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit
SHEET_ID=your-google-sheet-id
WORKSHEET_NAME=listings
# Local dev: path to the service-account JSON file.
GOOGLE_CREDENTIALS_FILE=credentials.json
# Cloud hosting: paste the whole JSON content here instead (one line).
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# --- Optional: scraping fallback when sites block plain requests ---
# ZENROWS_API_KEY=
